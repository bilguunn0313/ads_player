{
  "name": "video-player",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd api && npm run dev",
    "dev:web": "cd web && npm run dev",
    "build": "cd web && npm run build",
    "start": "cd api && npm start",
    "install:all": "cd api && npm install && cd ../web && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
